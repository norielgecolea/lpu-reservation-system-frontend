        </plugin>
        
        <plugin>
  			<groupId>org.apache.tomcat.maven</groupId>
  			<artifactId>tomcat7-maven-plugin</artifactId>
  			<version>2.2</version>
  			<configuration>
 			  <url>http://10.1.101.60:8080/manager/text</url>
   			 <username>admin</username>
    		<password>admin123</password>
    			<path>/lpu-reservation-system</path>
  			</configuration>
		</plugin>

